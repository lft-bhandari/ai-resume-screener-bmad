# =============================================================================
# Environment Configuration for bmad_evaluation_two backend
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- REQUIRED (no defaults — app will not start without these) ---

# Google Gemini API key for resume analysis
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# JWT signing secret key — MINIMUM 32 characters (HS256 requirement)
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-must-be-32-chars-minimum

# --- OPTIONAL (defaults shown below) ---

# Async SQLAlchemy database URL
# Default: SQLite file at backend/app.db (suitable for development)
# For Docker Compose, override to mount path: sqlite+aiosqlite:////data/app.db
DATABASE_URL=sqlite+aiosqlite:///./app.db

# Candidate data retention period in days (GDPR compliance)
# Records older than this are purged by the scheduled job (Epic 6)
RETENTION_DAYS=90

# Default admin user seeded on first run (created only if no users exist)
# IMPORTANT: Change these values before any non-development deployment!
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
